# tests/bcyr/vani.bcyr — CPU-only benchmark harness for vani
# Mirrors the mabda bench shape. All benches are pure CPU — no
# real device fd, no syscall latency in the hot path. The numbers
# track the cost of vani's userspace primitives:
#
#   ring write/read   — pow-of-2 byte ring (the playback hot path)
#   format math       — frame ↔ byte and ms ↔ frame conversions
#   hwp manipulation  — 608-byte struct init / mask / interval ops
#   negotiation       — mask query + format quality walk
#
# Usage: cyrius bench tests/bcyr/vani.bcyr
#
# History is appended to `bench-history.csv` in the repo root via
# the `CSV:` prefixed lines this file emits. Schema:
#   name,min_ns
# Add new benches here and the CSV row falls out automatically.

include "src/lib.cyr"
include "lib/bench.cyr"

# ================================================================
# Batch tuning — sub-1us ops need batched timing per lib/bench.cyr
# ================================================================
var BATCH_SIZE = 10000;
var ROUNDS     = 100;
var BIG_BATCH  = 1000;
var BIG_ROUNDS = 50;

fn _csv_row(b) {
    var name = load64(b);
    syscall(1, 1, "CSV:", 4);
    syscall(1, 1, name, strlen(name));
    syscall(1, 1, ",", 1);
    fmt_int(bench_min_ns(b));
    syscall(1, 1, "\n", 1);
    return 0;
}

# ================================================================
# format math
# ================================================================

fn bench_bytes_per_frame() {
    var b = bench_new("bytes_per_frame");
    var f = vani_format_default();
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            vani_bytes_per_frame(f);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

fn bench_frames_to_bytes() {
    var b = bench_new("frames_to_bytes");
    var f = vani_format_default();
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            vani_frames_to_bytes(f, 9600);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

fn bench_ms_to_frames() {
    var b = bench_new("ms_to_frames");
    var f = vani_format_default();
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            vani_ms_to_frames(f, 200);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
