fn bench_alsa_for() {
    var b = bench_new("alsa_for");
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            vani_alsa_for(16, 1);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

# ================================================================
# ring buffer
# ================================================================
# Per-call cost includes the inner byte-copy loop, so use the
# smaller batch. Source / dest buffers reused across iterations.

fn bench_ring_write_64b() {
    var b = bench_new("ring_write_64b");
    var rb = vani_ring_new(4096);
    var src = alloc(64);
    var ri = 0;
    while (ri < BIG_ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BIG_BATCH) {
            vani_ring_reset(rb);
            vani_ring_write(rb, src, 64);
            bi = bi + 1;
        }
        bench_batch_stop(b, BIG_BATCH);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

fn bench_ring_read_64b() {
    var b = bench_new("ring_read_64b");
    var rb = vani_ring_new(4096);
    var src = alloc(64);
    var dst = alloc(64);
    var ri = 0;
    while (ri < BIG_ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BIG_BATCH) {
            vani_ring_reset(rb);
            vani_ring_write(rb, src, 64);
            vani_ring_read(rb, dst, 64);
            bi = bi + 1;
        }
        bench_batch_stop(b, BIG_BATCH);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

fn bench_ring_used() {
    var b = bench_new("ring_used");
    var rb = vani_ring_new(4096);
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            vani_ring_used(rb);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

# ================================================================
# hwp struct manipulation
# ================================================================
# These are heavier — _hwp_init_any writes 608 bytes plus loops to
# fill 24 u32s and 36 u32s. Use big batch size.

fn bench_hwp_init_any() {
    var b = bench_new("hwp_init_any");
    var hwp = alloc(HWP_SIZE);
    var ri = 0;
    while (ri < BIG_ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BIG_BATCH) {
            _hwp_init_any(hwp);
            bi = bi + 1;
        }
        bench_batch_stop(b, BIG_BATCH);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

fn bench_hwp_mask_set_value() {
    var b = bench_new("hwp_mask_set_value");
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            _hwp_mask_set_value(hwp, SNDRV_PCM_HW_PARAM_FORMAT,
                                SND_PCM_FORMAT_S16_LE);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

fn bench_hwp_interval_set_exact() {
    var b = bench_new("hwp_interval_set_exact");
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            _hwp_interval_set_exact(hwp, 3, 48000);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

fn bench_hwp_mask_has_bit() {
    var b = bench_new("hwp_mask_has_bit");
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            _hwp_mask_has_bit(hwp, 1, SND_PCM_FORMAT_S16_LE);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
