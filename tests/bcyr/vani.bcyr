}

# ================================================================
# negotiation
# ================================================================

fn bench_negotiate_format_pick() {
    var b = bench_new("negotiate_format_pick");
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    var ri = 0;
    while (ri < ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BATCH_SIZE) {
            _negotiate_format_pick(hwp, SND_PCM_FORMAT_S16_LE);
            bi = bi + 1;
        }
        bench_batch_stop(b, BATCH_SIZE);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

# ================================================================
# Realistic workload: simulate one 200 ms playback worth of ring
# writes (9600 frames × 4 bytes/frame = 38400 bytes).
# ================================================================

fn bench_ring_200ms_playback() {
    var b = bench_new("ring_200ms_playback");
    var rb = vani_ring_new(65536);  # 64 KiB pow-of-2
    var src = alloc(38400);
    var ri = 0;
    while (ri < BIG_ROUNDS) {
        bench_batch_start(b);
        var bi = 0;
        while (bi < BIG_BATCH) {
            vani_ring_reset(rb);
            vani_ring_write(rb, src, 38400);
            bi = bi + 1;
        }
        bench_batch_stop(b, BIG_BATCH);
        ri = ri + 1;
    }
    bench_report(b); _csv_row(b);
    return 0;
}

# ================================================================
# Runner
# ================================================================

fn main() {
    alloc_init();
    bench_bytes_per_frame();
    bench_frames_to_bytes();
    bench_ms_to_frames();
    bench_alsa_for();
    bench_ring_used();
    bench_ring_write_64b();
    bench_ring_read_64b();
    bench_hwp_init_any();
    bench_hwp_mask_set_value();
    bench_hwp_interval_set_exact();
    bench_hwp_mask_has_bit();
    bench_negotiate_format_pick();
    bench_ring_200ms_playback();
    return 0;
}

var ec = main();
syscall(60, ec);
