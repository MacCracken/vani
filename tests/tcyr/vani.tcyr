# tests/tcyr/vani.tcyr — CPU-only test suite for vani
# Pure-data assertions — no real audio device required. Hardware
# integration tests (real PCM open/write) live under
# tests/integration/ and are gated on a sound card being present.
#
# Sections: error codes, format math, ring buffer.

include "src/lib.cyr"
include "lib/assert.cyr"

# ================================================================
# error.cyr
# ================================================================

fn test_error_codes_unique() {
    assert(VANI_ERR_NONE         != VANI_ERR_DEVICE_OPEN, "none != device_open");
    assert(VANI_ERR_DEVICE_OPEN  != VANI_ERR_DEVICE_BUSY, "device_open != busy");
    assert(VANI_ERR_HW_PARAMS    != VANI_ERR_SW_PARAMS,   "hw != sw params");
    assert(VANI_ERR_UNDERRUN     != VANI_ERR_OVERRUN,     "under != over");
    assert(VANI_ERR_BUFFER_FULL  != VANI_ERR_BUFFER_EMPTY, "full != empty");
    return 0;
}

fn test_vani_err_new_stores_fields() {
    var e = vani_err_new(VANI_ERR_WRITE, "short write");
    assert_eq(vani_err_code(e), VANI_ERR_WRITE, "code stored");
    var d = vani_err_detail(e);
    assert(d != 0, "detail stored");
    assert_eq(strlen(d), 11, "detail length");
    return 0;
}

fn test_vani_err_no_detail() {
    var e = vani_err(VANI_ERR_DEVICE_BUSY);
    assert_eq(vani_err_code(e), VANI_ERR_DEVICE_BUSY, "code stored");
    assert_eq(vani_err_detail(e), 0, "detail null");
    return 0;
}

fn test_vani_err_recoverable() {
    assert_eq(vani_err_is_recoverable(VANI_ERR_UNDERRUN),  1, "underrun recoverable");
    assert_eq(vani_err_is_recoverable(VANI_ERR_OVERRUN),   1, "overrun recoverable");
    assert_eq(vani_err_is_recoverable(VANI_ERR_SUSPENDED), 1, "suspended recoverable");
    assert_eq(vani_err_is_recoverable(VANI_ERR_DEVICE_OPEN), 0, "open is fatal");
    assert_eq(vani_err_is_recoverable(VANI_ERR_HW_PARAMS),   0, "hw_params is fatal");
    return 0;
}

fn test_vani_err_name_lookup() {
    assert_eq(strlen(vani_err_name(VANI_ERR_NONE)),       4,  "none");
    assert_eq(strlen(vani_err_name(VANI_ERR_UNDERRUN)),   8,  "underrun");
    assert_eq(strlen(vani_err_name(VANI_ERR_DEVICE_BUSY)), 11, "device busy");
    return 0;
}

# ================================================================
# format.cyr
# ================================================================

fn test_format_default_is_48k_stereo_s16() {
    var f = vani_format_default();
    assert_eq(vani_format_rate(f),      VANI_RATE_48K,         "rate 48k");
    assert_eq(vani_format_channels(f),  2,                     "stereo");
    assert_eq(vani_format_bit_depth(f), 16,                    "16-bit");
    assert_eq(vani_format_alsa(f),      SND_PCM_FORMAT_S16_LE, "S16_LE");
    return 0;
}

fn test_format_cd_is_44k_stereo_s16() {
    var f = vani_format_cd();
    assert_eq(vani_format_rate(f),     VANI_RATE_44K, "rate 44.1k");
    assert_eq(vani_format_channels(f), 2,             "stereo");
    return 0;
}

fn test_bytes_per_sample() {
    assert_eq(vani_bytes_per_sample(SND_PCM_FORMAT_S8),       1, "s8");
    assert_eq(vani_bytes_per_sample(SND_PCM_FORMAT_U8),       1, "u8");
    assert_eq(vani_bytes_per_sample(SND_PCM_FORMAT_S16_LE),   2, "s16");
    assert_eq(vani_bytes_per_sample(SND_PCM_FORMAT_S24_LE),   4, "s24 in 32");
    assert_eq(vani_bytes_per_sample(SND_PCM_FORMAT_S32_LE),   4, "s32");
    assert_eq(vani_bytes_per_sample(SND_PCM_FORMAT_FLOAT_LE), 4, "float");
    return 0;
}

fn test_bytes_per_frame_stereo_s16() {
    var f = vani_format_default();
    assert_eq(vani_bytes_per_frame(f), 4, "2ch * 2bytes = 4");
    return 0;
}

fn test_frames_to_bytes_roundtrip() {
    var f = vani_format_default();
    assert_eq(vani_frames_to_bytes(f, 1000), 4000, "1000 frames");
    assert_eq(vani_bytes_to_frames(f, 4000), 1000, "4000 bytes");
    return 0;
}

fn test_ms_to_frames_at_48k() {
    var f = vani_format_default();
    assert_eq(vani_ms_to_frames(f, 10),   480,  "10ms = 480 frames");
    assert_eq(vani_ms_to_frames(f, 1000), 48000, "1s = 48000 frames");
    return 0;
}

fn test_alsa_for_picks_signed_and_endian() {
    assert_eq(vani_alsa_for(8,  1), SND_PCM_FORMAT_S8,     "s8 signed");
    assert_eq(vani_alsa_for(8,  0), SND_PCM_FORMAT_U8,     "u8 unsigned");
    assert_eq(vani_alsa_for(16, 1), SND_PCM_FORMAT_S16_LE, "s16 le");
    assert_eq(vani_alsa_for(24, 1), SND_PCM_FORMAT_S24_LE, "s24 le");
    assert_eq(vani_alsa_for(32, 1), SND_PCM_FORMAT_S32_LE, "s32 le");
    return 0;
}

# ================================================================
# buffer.cyr
# ================================================================

fn test_ring_capacity_rounds_to_pow2() {
    var rb = vani_ring_new(1000);
    assert_eq(vani_ring_size(rb), 1024, "1000 → 1024");
    var rb2 = vani_ring_new(4096);
    assert_eq(vani_ring_size(rb2), 4096, "4096 stays 4096");
    return 0;
}

fn test_ring_starts_empty() {
    var rb = vani_ring_new(64);
    assert_eq(vani_ring_used(rb),     0,  "empty used");
    assert_eq(vani_ring_free(rb),     64, "full free");
    assert_eq(vani_ring_is_empty(rb), 1,  "is_empty");
    assert_eq(vani_ring_is_full(rb),  0,  "not full");
    return 0;
}

fn test_ring_write_then_read_roundtrip() {
    var rb = vani_ring_new(64);
    var src = alloc(8);
    store8(src,   65);
    store8(src+1, 66);
    store8(src+2, 67);
    store8(src+3, 68);
    var n = vani_ring_write(rb, src, 4);
    assert_eq(n, 4, "wrote 4");
    assert_eq(vani_ring_used(rb), 4, "used 4");
    var dst = alloc(8);
    var m = vani_ring_read(rb, dst, 4);
    assert_eq(m, 4, "read 4");
    assert_eq(load8(dst),   65, "A");
    assert_eq(load8(dst+1), 66, "B");
    assert_eq(load8(dst+2), 67, "C");
    assert_eq(load8(dst+3), 68, "D");
    assert_eq(vani_ring_used(rb), 0, "empty after drain");
    return 0;
}

fn test_ring_write_short_when_full() {
    var rb = vani_ring_new(8);
    var src = alloc(16);
    var i = 0;
    while (i < 16) { store8(src + i, i); i = i + 1; }
    var n = vani_ring_write(rb, src, 16);
    assert_eq(n, 8, "capped at size");
    assert_eq(vani_ring_is_full(rb), 1, "now full");
    return 0;
}

fn test_ring_wraps_around_mask() {
    var rb = vani_ring_new(8);
    var src = alloc(8);
    var i = 0;
    while (i < 8) { store8(src + i, i + 1); i = i + 1; }
    # Fill, drain 6, fill 6 more — second fill wraps the write index.
    vani_ring_write(rb, src, 8);
    var dst = alloc(8);
    vani_ring_read(rb, dst, 6);
    vani_ring_write(rb, src, 6);
    assert_eq(vani_ring_used(rb), 8, "back to full");
    return 0;
}

fn test_ring_reset_clears_positions() {
    var rb = vani_ring_new(16);
    var src = alloc(8);
    vani_ring_write(rb, src, 5);
    vani_ring_reset(rb);
    assert_eq(vani_ring_wpos(rb), 0, "wpos reset");
    assert_eq(vani_ring_rpos(rb), 0, "rpos reset");
    assert_eq(vani_ring_is_empty(rb), 1, "empty after reset");
    return 0;
}

# ================================================================
# device.cyr — pure-data accessors only (no real fd)
# ================================================================

fn test_direction_constants() {
    assert_eq(VANI_PLAYBACK, 0, "playback = 0");
    assert_eq(VANI_CAPTURE,  1, "capture = 1");
    return 0;
}

# ================================================================
# Audit 2026-04-30 regressions
# ================================================================
# Each fix lands with an assertion that would have caught the
# original bug. See docs/audit/2026-04-30-audit.md.

# MED-1: card / device numbers ≥ 10 must produce distinct paths
# from card 0 — the old `% 10` encoding silently collided.
fn test_audit_med1_card_10_not_collides_with_0() {
    var p0  = _audio_devpath(0,  0,  112);
    var p10 = _audio_devpath(10, 0,  112);
    assert(p0  != 0,  "card 0 path");
    assert(p10 != 0,  "card 10 path");
    # Compare byte-by-byte — they must differ at the card-digit slot.
    # /dev/snd/pcmC{0|10}D0p — diverge at offset 13.
    assert(load8(p10 + 13) == 49, "card 10 first digit '1'");
    assert(load8(p10 + 14) == 48, "card 10 second digit '0'");
    # Card 0 has a single digit at offset 13.
    assert(load8(p0 + 13)  == 48, "card 0 digit '0'");
    return 0;
}

fn test_audit_med1_card_99_max_supported() {
    var p99 = _audio_devpath(99, 0, 112);
    assert(p99 != 0, "card 99 still encodes");
    assert(load8(p99 + 13) == 57, "card 99 first digit '9'");
    assert(load8(p99 + 14) == 57, "card 99 second digit '9'");
    return 0;
}

fn test_audit_med1_card_100_rejected() {
    var p100 = _audio_devpath(100, 0, 112);
    assert_eq(p100, 0, "card 100 returns null");
    return 0;
}

fn test_audit_med1_negative_card_rejected() {
    var pneg = _audio_devpath(0 - 1, 0, 112);
    assert_eq(pneg, 0, "card -1 returns null");
    return 0;
}

fn test_audit_med1_ctl_path_two_digits() {
    var p10 = _vani_ctl_path(10);
    assert(p10 != 0, "controlC10 encodes");
    assert(load8(p10 + 17) == 49, "first digit '1'");
    assert(load8(p10 + 18) == 48, "second digit '0'");
    var p100 = _vani_ctl_path(100);
    assert_eq(p100, 0, "controlC100 rejected");
    return 0;
}

# LOW-1: malicious capacity must not loop the pow-of-2 helper.
fn test_audit_low1_ring_capacity_capped() {
    var rb = vani_ring_new(VANI_RING_MAX_BYTES + 1);
    assert_eq(rb, 0, "1 GiB + 1 byte rejected");
    var rb2 = vani_ring_new(VANI_RING_MAX_BYTES);
    assert(rb2 != 0, "exactly 1 GiB accepted");
    return 0;
}

fn test_audit_low1_next_pow2_bounds() {
    assert_eq(_next_pow2(0 - 1), 0, "negative rejected");
    assert_eq(_next_pow2(0),     0, "zero rejected");
    assert_eq(_next_pow2(VANI_RING_MAX_BYTES + 1), 0, "above cap rejected");
    return 0;
}

# DEFENSE-IN-DEPTH (CVE-2025-40269 class): audio_write/read must
# refuse frame counts that could trigger narrower-int kernel
# arithmetic. We can't actually call the syscall here without a
# real fd, but we can prove the bound exists.
fn test_audit_cve_2025_40269_frames_max_constant() {
    assert_eq(AUDIO_FRAMES_MAX, 268435456, "2^28 cap");
    return 0;
}

# ================================================================
# v0.2.0 — HW_PARAMS struct layout
# ================================================================
# The 608-byte snd_pcm_hw_params struct layout must match
# include/uapi/sound/asound.h exactly — these tests pin the offsets
# we depend on. Drift between a kernel UAPI bump and these tests
# is the regression we're guarding against.

fn test_hwp_layout_constants() {
    assert_eq(HWP_SIZE,           608, "struct is 608 bytes");
    assert_eq(HWP_MASKS_BASE,     4,   "masks start after flags");
    assert_eq(HWP_MASK_BYTES,     32,  "snd_mask is 32 B");
    assert_eq(HWP_INTERVAL_BASE,  260, "intervals at +260");
    assert_eq(HWP_INTERVAL_BYTES, 12,  "snd_interval is 12 B");
    assert_eq(HWP_RMASK_OFF,      512, "rmask at +512");
    assert_eq(HWP_CMASK_OFF,      516, "cmask at +516");
    return 0;
}

# Pin the size-bits inside each ioctl number. Drift here means the
# kernel will reject with ENOTTY (caught on 2026-04-30 against
# WRITEI/READI_FRAMES). The size lives in bits 16..29 — extract
# with (cmd >> 16) & 0x3FFF.
fn test_ioctl_size_encoding_matches_struct_size() {
    # HW_PARAMS / HW_REFINE — 608 bytes
    assert_eq((SNDRV_PCM_IOCTL_HW_PARAMS >> 16) & 16383, 608, "HW_PARAMS=608");
    assert_eq((SNDRV_PCM_IOCTL_HW_REFINE >> 16) & 16383, 608, "HW_REFINE=608");
    # SW_PARAMS — 136 bytes
    assert_eq((SNDRV_PCM_IOCTL_SW_PARAMS >> 16) & 16383, 136, "SW_PARAMS=136");
    # STATUS — 152 bytes (truncated to fit 14-bit size; older kernels)
    assert_eq((SNDRV_PCM_IOCTL_STATUS    >> 16) & 16383, 152, "STATUS=152");
    # WRITEI / READI — 24 bytes (snd_xferi: result+buf+frames)
    assert_eq((SNDRV_PCM_IOCTL_WRITEI_FRAMES >> 16) & 16383, 24, "WRITEI=24");
    assert_eq((SNDRV_PCM_IOCTL_READI_FRAMES  >> 16) & 16383, 24, "READI=24");
    # Direction-only ioctls (no struct) carry size=0
    assert_eq((SNDRV_PCM_IOCTL_PREPARE >> 16) & 16383, 0, "PREPARE=0");
    assert_eq((SNDRV_PCM_IOCTL_START   >> 16) & 16383, 0, "START=0");
    assert_eq((SNDRV_PCM_IOCTL_DROP    >> 16) & 16383, 0, "DROP=0");
    assert_eq((SNDRV_PCM_IOCTL_DRAIN   >> 16) & 16383, 0, "DRAIN=0");
    return 0;
}

# Pin the type byte too — must be 'A' (0x41) for all SNDRV_PCM_*.
fn test_ioctl_type_is_A() {
    assert_eq((SNDRV_PCM_IOCTL_HW_PARAMS     >> 8) & 255, 0x41, "HW_PARAMS");
    assert_eq((SNDRV_PCM_IOCTL_HW_REFINE     >> 8) & 255, 0x41, "HW_REFINE");
    assert_eq((SNDRV_PCM_IOCTL_PREPARE       >> 8) & 255, 0x41, "PREPARE");
    assert_eq((SNDRV_PCM_IOCTL_START         >> 8) & 255, 0x41, "START");
    assert_eq((SNDRV_PCM_IOCTL_WRITEI_FRAMES >> 8) & 255, 0x41, "WRITEI");
    assert_eq((SNDRV_PCM_IOCTL_READI_FRAMES  >> 8) & 255, 0x41, "READI");
    return 0;
}

fn test_hwp_mask_offsets() {
    assert_eq(_hwp_mask_off(0), 4,   "ACCESS at +4");
    assert_eq(_hwp_mask_off(1), 36,  "FORMAT at +36");
    assert_eq(_hwp_mask_off(2), 68,  "SUBFORMAT at +68");
    return 0;
}

fn test_hwp_interval_offsets() {
    # interval slot 0 (SAMPLE_BITS) at +260, slot 11 (TICK_TIME) at +260+132=+392
    assert_eq(_hwp_interval_off(0),  260, "slot 0 at +260");
    assert_eq(_hwp_interval_off(2),  284, "CHANNELS slot 2 at +284");
    assert_eq(_hwp_interval_off(3),  296, "RATE slot 3 at +296");
    assert_eq(_hwp_interval_off(11), 392, "TICK_TIME slot 11 at +392");
    return 0;
}

fn test_hwp_init_any_fills_correctly() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # load32 zero-extends to i64, so 0xFFFFFFFF reads as 4294967295.
    var u32_max = 4294967295;
    # All three active masks should have all bits set in word 0.
    assert_eq(load32(hwp + _hwp_mask_off(0)),     u32_max, "mask 0 word 0");
    assert_eq(load32(hwp + _hwp_mask_off(1)),     u32_max, "mask 1 word 0");
    assert_eq(load32(hwp + _hwp_mask_off(2)),     u32_max, "mask 2 word 0");
    # Intervals: min=0, max=0xFFFFFFFF, flags=0
    assert_eq(load32(hwp + _hwp_interval_off(0) + 0), 0,       "int 0 min = 0");
    assert_eq(load32(hwp + _hwp_interval_off(0) + 4), u32_max, "int 0 max = UINT_MAX");
    assert_eq(load32(hwp + _hwp_interval_off(0) + 8), 0,       "int 0 flags = 0");
    # rmask = all
    assert_eq(load32(hwp + HWP_RMASK_OFF), u32_max, "rmask = all");
    return 0;
}

fn test_hwp_mask_set_value_single_bit() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # Constrain FORMAT (mask 1) to S16_LE (bit 2).
    _hwp_mask_set_value(hwp, SNDRV_PCM_HW_PARAM_FORMAT, SND_PCM_FORMAT_S16_LE);
    # Word 0 should now be exactly (1 << 2) = 4
    assert_eq(load32(hwp + _hwp_mask_off(1)),     4, "FORMAT mask = bit 2 only");
    # Other words should be zero
    assert_eq(load32(hwp + _hwp_mask_off(1) + 4), 0, "FORMAT mask word 1 = 0");
    return 0;
}

fn test_hwp_mask_set_value_high_bit() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # Set bit 33 in mask 0 — should land in word 1, bit 1.
    _hwp_mask_set_value(hwp, 0, 33);
    assert_eq(load32(hwp + _hwp_mask_off(0) + 0), 0, "word 0 cleared");
    assert_eq(load32(hwp + _hwp_mask_off(0) + 4), 2, "word 1 = bit 1");
    return 0;
}

fn test_hwp_interval_set_exact_writes_min_max_flag() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # Set RATE (slot 3) to exactly 48000.
    _hwp_interval_set_exact(hwp, 3, 48000);
    var off = _hwp_interval_off(3);
    assert_eq(load32(hwp + off + 0), 48000, "min = 48000");
    assert_eq(load32(hwp + off + 4), 48000, "max = 48000");
    assert_eq(load32(hwp + off + 8), SND_INTERVAL_INTEGER, "integer flag");
    return 0;
}

fn test_alsa_format_for_bits() {
    assert_eq(_alsa_format_for_bits(8),  SND_PCM_FORMAT_S8,     "8 → S8");
    assert_eq(_alsa_format_for_bits(16), SND_PCM_FORMAT_S16_LE, "16 → S16_LE");
    assert_eq(_alsa_format_for_bits(24), SND_PCM_FORMAT_S24_LE, "24 → S24_LE");
    assert_eq(_alsa_format_for_bits(32), SND_PCM_FORMAT_S32_LE, "32 → S32_LE");
    assert_eq(_alsa_format_for_bits(7),  0 - 1,                 "7 → -1");
    return 0;
}

fn test_alsa_bits_for_format() {
    assert_eq(_alsa_bits_for_format(SND_PCM_FORMAT_S8),       8,  "S8");
    assert_eq(_alsa_bits_for_format(SND_PCM_FORMAT_U8),       8,  "U8");
    assert_eq(_alsa_bits_for_format(SND_PCM_FORMAT_S16_LE),   16, "S16_LE");
    assert_eq(_alsa_bits_for_format(SND_PCM_FORMAT_S24_LE),   24, "S24_LE");
    assert_eq(_alsa_bits_for_format(SND_PCM_FORMAT_S32_LE),   32, "S32_LE");
    assert_eq(_alsa_bits_for_format(SND_PCM_FORMAT_FLOAT_LE), 32, "FLOAT_LE");
    assert_eq(_alsa_bits_for_format(99),                       0,  "unknown → 0");
    return 0;
}

# ================================================================
# v0.2.0 — HW_REFINE readers + format negotiation
# ================================================================

fn test_hwp_mask_has_bit_after_init_any() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # All bits set in the 3 active masks, so any bit query is 1.
    assert_eq(_hwp_mask_has_bit(hwp, 0, 0),   1, "ACCESS bit 0");
    assert_eq(_hwp_mask_has_bit(hwp, 1, 2),   1, "FORMAT S16_LE");
    assert_eq(_hwp_mask_has_bit(hwp, 1, 14),  1, "FORMAT FLOAT_LE");
    assert_eq(_hwp_mask_has_bit(hwp, 2, 0),   1, "SUBFORMAT STD");
    return 0;
}

fn test_hwp_mask_has_bit_after_constraint() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    _hwp_mask_set_value(hwp, 1, SND_PCM_FORMAT_S16_LE);
    assert_eq(_hwp_mask_has_bit(hwp, 1, SND_PCM_FORMAT_S16_LE), 1, "S16_LE on");
    assert_eq(_hwp_mask_has_bit(hwp, 1, SND_PCM_FORMAT_S32_LE), 0, "S32_LE off");
    assert_eq(_hwp_mask_has_bit(hwp, 1, SND_PCM_FORMAT_S8),     0, "S8 off");
    return 0;
}

fn test_hwp_mask_has_bit_out_of_range() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    assert_eq(_hwp_mask_has_bit(hwp, 0, 0 - 1), 0, "negative bit");
    assert_eq(_hwp_mask_has_bit(hwp, 0, 256),   0, "bit > 255");
    return 0;
}

fn test_hwp_interval_readers() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    _hwp_interval_set_exact(hwp, 3, 48000);
    assert_eq(_hwp_interval_min(hwp, 3), 48000, "min");
    assert_eq(_hwp_interval_max(hwp, 3), 48000, "max");
    assert_eq(_hwp_interval_contains(hwp, 3, 48000), 1, "contains exact");
    assert_eq(_hwp_interval_contains(hwp, 3, 47999), 0, "below");
    assert_eq(_hwp_interval_contains(hwp, 3, 48001), 0, "above");
    return 0;
}

fn test_clamp() {
    assert_eq(_clamp(50, 0, 100),  50, "in range");
    assert_eq(_clamp(0 - 5, 0, 100), 0, "below clamps to lo");
    assert_eq(_clamp(150, 0, 100), 100, "above clamps to hi");
    assert_eq(_clamp(0, 0, 100),   0, "at lo");
    assert_eq(_clamp(100, 0, 100), 100, "at hi");
    return 0;
}

# Negotiate-format picker: preferred supported → return preferred.
fn test_negotiate_picks_preferred_when_supported() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    var picked = _negotiate_format_pick(hwp, SND_PCM_FORMAT_S16_LE);
    assert_eq(picked, SND_PCM_FORMAT_S16_LE, "preferred S16_LE");
    return 0;
}

# Preferred not supported, S32_LE supported → return S32_LE.
fn test_negotiate_falls_back_to_s32() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # Constrain FORMAT mask to ONLY S32_LE.
    _hwp_mask_set_value(hwp, SNDRV_PCM_HW_PARAM_FORMAT, SND_PCM_FORMAT_S32_LE);
    # Ask for FLOAT_LE (not in mask) — should fall back to S32_LE.
    var picked = _negotiate_format_pick(hwp, SND_PCM_FORMAT_FLOAT_LE);
    assert_eq(picked, SND_PCM_FORMAT_S32_LE, "fallback S32_LE");
    return 0;
}

# Only S8 supported → return S8 even when preferred is S24_LE.
fn test_negotiate_falls_back_to_s8() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    _hwp_mask_set_value(hwp, SNDRV_PCM_HW_PARAM_FORMAT, SND_PCM_FORMAT_S8);
    var picked = _negotiate_format_pick(hwp, SND_PCM_FORMAT_S24_LE);
    assert_eq(picked, SND_PCM_FORMAT_S8, "fallback S8");
    return 0;
}

# Empty mask (no formats) → -1.
fn test_negotiate_no_formats_returns_neg() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # Clear FORMAT mask entirely.
    var moff = _hwp_mask_off(SNDRV_PCM_HW_PARAM_FORMAT);
    var w = 0;
    while (w < 8) { store32(hwp + moff + w * 4, 0); w = w + 1; }
    var picked = _negotiate_format_pick(hwp, SND_PCM_FORMAT_S16_LE);
    assert_eq(picked, 0 - 1, "no formats → -1");
    return 0;
}

# Quality preference: when multiple formats supported, S32_LE wins
# over S16_LE / S8 if preferred isn't in the mask.
fn test_negotiate_quality_preference() {
    var hwp = alloc(HWP_SIZE);
    _hwp_init_any(hwp);
    # Clear mask, then enable S32_LE + S16_LE + S8 only.
    var moff = _hwp_mask_off(SNDRV_PCM_HW_PARAM_FORMAT);
    var w = 0;
    while (w < 8) { store32(hwp + moff + w * 4, 0); w = w + 1; }
    _hwp_mask_set_value(hwp, SNDRV_PCM_HW_PARAM_FORMAT, SND_PCM_FORMAT_S32_LE);
    # _hwp_mask_set_value clears first then sets bit, so we re-set the others manually.
    var slot0 = hwp + moff;
    store32(slot0, load32(slot0)
        | (1 << SND_PCM_FORMAT_S16_LE)
        | (1 << SND_PCM_FORMAT_S8));
    # FLOAT_LE not in mask — quality walk picks S32_LE first.
    var picked = _negotiate_format_pick(hwp, SND_PCM_FORMAT_FLOAT_LE);
    assert_eq(picked, SND_PCM_FORMAT_S32_LE, "quality picks S32 over S16/S8");
    return 0;
}

