# programs/mixer_test.cyr — read-only mixer probe
#
# Opens the control device for a card, enumerates every mixer
# element via vani_mixer_list_elements, then for each element
# tries vani_mixer_get_volume / vani_mixer_get_mute and prints
# the result. **Read-only.** No writes that change audio state.
#
# Roadmap v0.3.0 #2-#7. Verifies the snd_ctl_elem_id /
# snd_ctl_elem_info / snd_ctl_elem_value / snd_ctl_elem_list
# struct layouts against real hardware.
#
# Defaults to card 1 — edit MIXER_CARD for your hardware.

include "src/lib.cyr"

enum MixerTestCfg {
    MIXER_CARD = 1;
}

fn _puts(s) { syscall(1, 1, s, strlen(s)); return 0; }

fn _puti(n) {
    var buf[24];
    var i = 23;
    store8(&buf + i, 0);
    if (n == 0) {
        i = i - 1;
        store8(&buf + i, 48);
        syscall(1, 1, &buf + i, 23 - i);
        return 0;
    }
    var neg = 0;
    if (n < 0) { neg = 1; n = 0 - n; }
    while (n > 0) {
        i = i - 1;
        store8(&buf + i, 48 + (n % 10));
        n = n / 10;
    }
    if (neg == 1) { i = i - 1; store8(&buf + i, 45); }
    syscall(1, 1, &buf + i, 23 - i);
    return 0;
}

fn main() {
    alloc_init();
    _puts("vani mixer probe — card ");
    _puti(MIXER_CARD);
    _puts("\n");

    var ores = vani_mixer_open(MIXER_CARD);
    if (is_ok(ores) == 0) {
        _puts("open: FAIL\n");
        return 1;
    }
    var m = payload(ores);
    _puts("  open: OK\n");

    var lres = vani_mixer_list_elements(m);
    if (is_ok(lres) == 0) {
        _puts("list: FAIL\n");
        vani_mixer_close(m);
        return 1;
    }
    var lh = payload(lres);
    var n = vani_mixer_list_count(lh);
    _puts("  elements: ");
    _puti(n);
    _puts("\n");

    var name_buf = alloc(48);
    var info[272];
    var i = 0;
    while (i < n) {
        vani_mixer_list_name(lh, i, name_buf);
        _puts("    ");

        # Print right-aligned-ish: index then name.
        if (i < 10) { _puts(" "); }
        _puti(i);
        _puts(". ");
        syscall(1, 1, name_buf, strlen(name_buf));

        # Query info to learn the type.
        var r = _vani_mixer_elem_info(m, name_buf, &info);
        if (r < 0) {
            _puts("  [info FAIL]\n");
            i = i + 1;
            continue;
        }
        var t     = load32(&info + CTL_ELEM_INFO_TYPE);
        var count = load32(&info + CTL_ELEM_INFO_COUNT);

        if (t == SNDRV_CTL_ELEM_TYPE_INTEGER) {
            var min = load64(&info + CTL_ELEM_INFO_INTEGER_MIN);
            var max = load64(&info + CTL_ELEM_INFO_INTEGER_MAX);
            _puts("  [INT range=");
            _puti(min);
            _puts("..");
            _puti(max);
            _puts(" count=");
            _puti(count);
            _puts("]");
            var vres = vani_mixer_get_volume(m, name_buf);
            if (is_ok(vres) == 1) {
                _puts(" → ");
                _puti(payload(vres));
                _puts("%");
            }
        } else {
            if (t == SNDRV_CTL_ELEM_TYPE_BOOLEAN) {
                _puts("  [BOOL count=");
                _puti(count);
                _puts("]");
                var bres = vani_mixer_get_mute(m, name_buf);
                if (is_ok(bres) == 1) {
                    if (payload(bres) == 1) { _puts(" → MUTED"); }
                    if (payload(bres) == 0) { _puts(" → on"); }
                }
            } else {
                _puts("  [type=");
                _puti(t);
                _puts(" count=");
                _puti(count);
                _puts("]");
            }
        }
        _puts("\n");
        i = i + 1;
    }

    vani_mixer_close(m);
    _puts("MIXER PROBE PASS\n");
    return 0;
}

var ec = main();
syscall(60, ec);
