# ================================================================
# SW_PARAMS struct (v0.4.0 #3)
# ================================================================
# `struct snd_pcm_sw_params` is 136 bytes on x86_64. Field layout
# verified 2026-04-30 against include/uapi/sound/asound.h:
#   +0   tstamp_mode        i32
#   +4   period_step        u32
#   +8   sleep_min          u32
#   (+12 4-byte padding for snd_pcm_uframes_t 8-byte alignment)
#   +16  avail_min          u64  — kernel wakes us when this many frames are free
#   +24  xfer_align         u64  — write/read alignment (1 = byte-granular)
#   +32  start_threshold    u64  — auto-start when this many frames buffered
#   +40  stop_threshold     u64  — XRUN if buffer drains below boundary - this
#   +48  silence_threshold  u64  — fill silence when avail dips this low (0 disabled)
#   +56  silence_size       u64
#   +64  boundary           u64  — wraparound point for ring-position math
#   +72  proto              u32
#   +76  tstamp_type        u32
#   +80  reserved[56]
# = 136 bytes total

enum AlsaSwParamsLayout {
    SWP_SIZE              = 136;
    SWP_TSTAMP_MODE       = 0;
    SWP_PERIOD_STEP       = 4;
    SWP_SLEEP_MIN         = 8;
    SWP_AVAIL_MIN         = 16;
    SWP_XFER_ALIGN        = 24;
    SWP_START_THRESHOLD   = 32;
    SWP_STOP_THRESHOLD    = 40;
    SWP_SILENCE_THRESHOLD = 48;
    SWP_SILENCE_SIZE      = 56;
    SWP_BOUNDARY          = 64;
    SWP_PROTO             = 72;
    SWP_TSTAMP_TYPE       = 76;
}

# Initialize an snd_ctl_elem_id (eid must be 64 bytes).
# `name` is a null-terminated cstr. We copy up to 43 bytes and
# null-terminate at +59 to satisfy the kernel's strict length
# check on the 44-byte name field.
fn _ctl_elem_id_init(eid, iface, name): i64 {
    memset(eid, 0, CTL_ELEM_ID_SIZE);
    store32(eid + CTL_ELEM_ID_IFACE, iface);
    var nlen = strlen(name);
    if (nlen > CTL_ELEM_ID_NAME_LEN - 1) {
        nlen = CTL_ELEM_ID_NAME_LEN - 1;
    }
    memcpy(eid + CTL_ELEM_ID_NAME_OFF, name, nlen);
    return 0;
}

# Read the name field out of an snd_ctl_elem_id buffer at offset
# `id_off`. Caller's `out_buf` must be at least 45 bytes (44 + null).
fn _ctl_elem_id_get_name(buf_with_id, id_off, out_buf): i64 {
    memcpy(out_buf, buf_with_id + id_off + CTL_ELEM_ID_NAME_OFF,
    CTL_ELEM_ID_NAME_LEN);
    store8(out_buf + CTL_ELEM_ID_NAME_LEN, 0);
    return out_buf;
}

# ================================================================
# HW_PARAMS struct readers — for HW_REFINE result inspection
# ================================================================
# After SNDRV_PCM_IOCTL_HW_REFINE the kernel narrows the masks and
# intervals to what the device actually supports. These accessors
# read those narrowed values back out.

# Test if mask `mask_idx` has bit `bit` set. Returns 0 or 1.
fn _hwp_mask_has_bit(hwp, mask_idx, bit): i64 {
    if (bit < 0)   { return 0; }
    if (bit > 255) { return 0; }
    var word_off = _hwp_mask_off(mask_idx) + (bit / 32) * 4;
    var word = load32(hwp + word_off);
    return (word >> (bit & 31)) & 1;
}

fn _hwp_interval_min(hwp, int_idx): i64 {
    return load32(hwp + _hwp_interval_off(int_idx) + 0);
}

fn _hwp_interval_max(hwp, int_idx): i64 {
    return load32(hwp + _hwp_interval_off(int_idx) + 4);
}

fn _hwp_interval_contains(hwp, int_idx, value): i64 {
    if (value < _hwp_interval_min(hwp, int_idx)) { return 0; }
    if (value > _hwp_interval_max(hwp, int_idx)) { return 0; }
    return 1;
}

# ================================================================
# Audio device handle
# ================================================================
# Layout (32 bytes):
#   +0  fd          file descriptor
#   +8  rate        sample rate
#   +16 channels    channel count
#   +24 bit_depth   bits per sample

# Open ALSA playback device, returns handle or 0 on failure
fn audio_open_playback(card, device): i64 {
    var path = _audio_devpath(card, device, 112);
    if (path == 0) { return 0; }
    var fd = sys_open(path, 1, 0);
    if (fd < 0) { return 0; }
    var dev = alloc(32);
    store64(dev, fd);
    store64(dev + 8, 0);
    store64(dev + 16, 0);
    store64(dev + 24, 0);
    return dev;
}

# Open ALSA capture device, returns handle or 0 on failure
fn audio_open_capture(card, device): i64 {
    var path = _audio_devpath(card, device, 99);
    if (path == 0) { return 0; }
    var fd = sys_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var dev = alloc(32);
    store64(dev, fd);
    store64(dev + 8, 0);
    store64(dev + 16, 0);
    store64(dev + 24, 0);
    return dev;
}

# Close audio device and release resources
fn audio_close(dev): i64 {
    if (dev == 0) { return 0; }
    var fd = load64(dev);
    syscall(SYS_IOCTL, fd, SNDRV_PCM_IOCTL_DROP, 0);
    sys_close(fd);
    return 0;
}

# Get file descriptor from audio device handle
fn audio_fd(dev): i64 { return load64(dev); }
# Get sample rate from audio device handle
fn audio_rate(dev): i64 { return load64(dev + 8); }
# Get channel count from audio device handle
fn audio_channels(dev): i64 { return load64(dev + 16); }
# Get bits per sample from audio device handle
fn audio_bit_depth(dev): i64 { return load64(dev + 24); }

# ================================================================
# Hardware params — full SNDRV_PCM_IOCTL_HW_PARAMS (v0.2.0)
# ================================================================
# Builds the 608-byte struct in stack scratch space, sets all params
# to "any" (all bits set / [0, UINT_MAX]), then constrains:
#   ACCESS    = RW_INTERLEAVED
#   FORMAT    = derived from bit_depth (signed LE for 8/16/24/32)
#   SUBFORMAT = STD
#   CHANNELS  = exact value passed
#   RATE      = exact value passed
# Period / buffer / fifo are left "any" — the kernel picks defaults
# for the device, which is the right behaviour for v0.2.0. v0.4.0
# adds explicit `audio_set_period` / `audio_set_buffer` for
# low-latency callers.
#
# Returns 0 on success, negative on failure (errno-shaped).
#
# `period_frames=0` and/or `buffer_frames=0` leaves those params
# "any" — the kernel picks defaults for the device. Pass non-zero
# to constrain explicitly (used by latency presets in device.cyr).

fn audio_set_params_full(dev, rate, channels, bit_depth,
period_frames, buffer_frames): i64 {
    if (dev == 0)       { return 0 - 1; }
    if (rate <= 0)      { return 0 - 1; }
    if (channels <= 0)  { return 0 - 1; }
    var fmt = _alsa_format_for_bits(bit_depth);
    if (fmt < 0)        { return 0 - 1; }

    var hwp[608];
    _hwp_init_any(&hwp);

    # ACCESS = RW_INTERLEAVED. Most reliable across drivers.
    _hwp_mask_set_value(&hwp,
    SNDRV_PCM_HW_PARAM_ACCESS,
    SND_PCM_ACCESS_RW_INTERLEAVED);

    # FORMAT — derived from bit_depth.
    _hwp_mask_set_value(&hwp, SNDRV_PCM_HW_PARAM_FORMAT, fmt);

    # SUBFORMAT = STD. Required — leaving "any" rejects on some drivers.
    _hwp_mask_set_value(&hwp,
    SNDRV_PCM_HW_PARAM_SUBFORMAT,
    SND_PCM_SUBFORMAT_STD);

    # CHANNELS, RATE — exact. interval slot = param - FIRST_INTERVAL.
    _hwp_interval_set_exact(&hwp,
    SNDRV_PCM_HW_PARAM_CHANNELS - SNDRV_PCM_HW_PARAM_FIRST_INTERVAL,
    channels);
    _hwp_interval_set_exact(&hwp,
    SNDRV_PCM_HW_PARAM_RATE - SNDRV_PCM_HW_PARAM_FIRST_INTERVAL,
    rate);

    if (period_frames > 0) {
        _hwp_interval_set_exact(&hwp,
        SNDRV_PCM_HW_PARAM_PERIOD_SIZE - SNDRV_PCM_HW_PARAM_FIRST_INTERVAL,
        period_frames);
    }
    if (buffer_frames > 0) {
        _hwp_interval_set_exact(&hwp,
        SNDRV_PCM_HW_PARAM_BUFFER_SIZE - SNDRV_PCM_HW_PARAM_FIRST_INTERVAL,
        buffer_frames);
    }

    var r = syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_HW_PARAMS, &hwp);
    if (r < 0) { return r; }

    # Cache the negotiated params on the handle for later queries.
    store64(dev + 8, rate);
    store64(dev + 16, channels);
    store64(dev + 24, bit_depth);
    return 0;
}

# Backwards-compatible 4-arg form — kernel picks period / buffer.
fn audio_set_params(dev, rate, channels, bit_depth): i64 {
    return audio_set_params_full(dev, rate, channels, bit_depth, 0, 0);
}

# ================================================================
# SW_PARAMS configuration (v0.4.0 #3)
# ================================================================
# Sets start_threshold / stop_threshold / avail_min on a device
# already through HW_PARAMS (i.e. in SETUP state). The other SW
# fields take sane defaults:
#   period_step = 1, xfer_align = 1, silence threshold/size = 0,
#   boundary = AUDIO_FRAMES_MAX (2^28 — plenty of wraparound headroom).
# Call BEFORE prepare() — kernel rejects SW_PARAMS once running.

fn audio_set_sw_params(dev, start_threshold, stop_threshold, avail_min): i64 {
    if (dev == 0)               { return 0 - 1; }
    if (start_threshold < 0)    { return 0 - 1; }
    if (stop_threshold < 0)     { return 0 - 1; }
    if (avail_min < 0)          { return 0 - 1; }
    var swp[136];
    memset(&swp, 0, SWP_SIZE);
    store32(&swp + SWP_PERIOD_STEP, 1);
    store64(&swp + SWP_AVAIL_MIN,         avail_min);
    store64(&swp + SWP_XFER_ALIGN,        1);
    store64(&swp + SWP_START_THRESHOLD,   start_threshold);
    store64(&swp + SWP_STOP_THRESHOLD,    stop_threshold);
    store64(&swp + SWP_SILENCE_THRESHOLD, 0);
    store64(&swp + SWP_SILENCE_SIZE,      0);
    store64(&swp + SWP_BOUNDARY,          AUDIO_FRAMES_MAX);
    return syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_SW_PARAMS, &swp);
}

# ================================================================
# Suspend / resume (v0.4.0 #4)
# ================================================================
# When the system suspends, the PCM goes to SND_PCM_STATE_SUSPENDED
# and stays there until resume. SNDRV_PCM_IOCTL_RESUME (no payload)
# transitions back; older kernels don't implement it and return
# -ENOSYS — caller should fall back to prepare in that case.

fn audio_resume(dev): i64 {
    if (dev == 0) { return 0 - 1; }
    return syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_RESUME, 0);
}

# ================================================================
# Capability query — SNDRV_PCM_IOCTL_HW_REFINE
# ================================================================
# REFINE asks the kernel "given these constraints, what subset of
# masks / intervals is actually supported?" — without applying any
# state transition. Caller passes a 608-byte buffer, we fill it
# with all-bits-set / full-range values, then ioctl writes back
# the narrowed view. Returns 0 on success, negative on failure.
#
# Use case: `vani_format_negotiate` consumes the result to pick a
# format the device can actually produce.

fn audio_query_caps(dev, hwp): i64 {
    if (dev == 0) { return 0 - 1; }
    if (hwp == 0) { return 0 - 1; }
    _hwp_init_any(hwp);
    return syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_HW_REFINE, hwp);
}

# Lower-level: ask whether a specific (rate, channels, bit_depth)
# combination is supported. Builds the same struct as
# `audio_set_params` but uses HW_REFINE — no state change.
# Returns 1 if supported, 0 if not, negative on syscall failure.
fn audio_can_set_params(dev, rate, channels, bit_depth): i64 {
    if (dev == 0)      { return 0 - 1; }
    if (rate <= 0)     { return 0 - 1; }
    if (channels <= 0) { return 0 - 1; }
    var fmt = _alsa_format_for_bits(bit_depth);
    if (fmt < 0) { return 0; }

    var hwp[608];
    _hwp_init_any(&hwp);
    _hwp_mask_set_value(&hwp,
    SNDRV_PCM_HW_PARAM_ACCESS,
    SND_PCM_ACCESS_RW_INTERLEAVED);
    _hwp_mask_set_value(&hwp, SNDRV_PCM_HW_PARAM_FORMAT, fmt);
    _hwp_mask_set_value(&hwp,
    SNDRV_PCM_HW_PARAM_SUBFORMAT,
    SND_PCM_SUBFORMAT_STD);
    _hwp_interval_set_exact(&hwp,
    SNDRV_PCM_HW_PARAM_CHANNELS - SNDRV_PCM_HW_PARAM_FIRST_INTERVAL,
    channels);
    _hwp_interval_set_exact(&hwp,
    SNDRV_PCM_HW_PARAM_RATE - SNDRV_PCM_HW_PARAM_FIRST_INTERVAL,
    rate);
    var r = syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_HW_REFINE, &hwp);
    if (r < 0) { return 0; }
    return 1;
}

# ================================================================
# PCM control
# ================================================================

# Prepare PCM device for playback or capture
fn audio_prepare(dev): i64 {
    return syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_PREPARE, 0);
}

# Start PCM playback or capture
fn audio_start(dev): i64 {
    return syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_START, 0);
}

# Immediately stop PCM and discard pending frames
fn audio_drop(dev): i64 {
    return syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_DROP, 0);
}

# Stop PCM after all pending frames are played
fn audio_drain(dev): i64 {
    return syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_DRAIN, 0);
}

# ================================================================
# Read / Write
# ================================================================
# `struct snd_xferi` is 24 bytes:
#   +0  result  i64  — kernel writes frames-actually-transferred
#   +8  buf     ptr  — caller writes sample buffer pointer
#   +16 frames  u64  — caller writes frames-to-transfer
# The ioctl return value is 0 on success, negative errno on failure.
# Frame count is read from the `result` field — NOT from `frames`,
# which is a pure input that the kernel doesn't touch.
#
# Audit 2026-04-30 corrected `var xferi[2]` → `var xferi[16]` but
# the kernel struct is actually 24 bytes; passing a 16-byte buffer
# meant the kernel read our `frames` value as a buf pointer and
# bailed with ENOTTY (-25). Fixed here while wiring v0.2.0 #9
# throughput. Filed as audit follow-up for the next P(-1) sweep.
#
# AUDIO_FRAMES_MAX (defense-in-depth, audit 2026-04-30): cap the
# frame count we hand to SNDRV_PCM_IOCTL_*I_FRAMES at 256 M frames
# (~24 h of 192 kHz mono, more than any real session). Mitigates
# the CVE-2025-40269 class — kernel transfer paths that did
# narrower-int arithmetic on (frames * bytes_per_frame).

enum AudioBounds {
    AUDIO_FRAMES_MAX = 268435456;  # 2^28
}

# Write interleaved frames to playback device.
# buf:    pointer to sample data (interleaved)
# frames: number of frames (1 frame = channels * bytes_per_sample)
# Returns: number of frames written, or negative on error.
fn audio_write(dev, buf, frames): i64 {
    if (frames < 0)                { return 0 - 1; }
    if (frames > AUDIO_FRAMES_MAX) { return 0 - 1; }
    var xferi[24];
    store64(&xferi,      0);       # result (kernel writes here)
    store64(&xferi + 8,  buf);     # buf
    store64(&xferi + 16, frames);  # frames-in
    var r = syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_WRITEI_FRAMES, &xferi);
    if (r < 0) { return r; }
    return load64(&xferi);  # result field — frames-actually-written
}

# Read interleaved frames from capture device.
# buf:    pointer to buffer for sample data
# frames: number of frames to read
# Returns: number of frames read, or negative on error.
fn audio_read(dev, buf, frames): i64 {
    if (frames < 0)                { return 0 - 1; }
    if (frames > AUDIO_FRAMES_MAX) { return 0 - 1; }
    var xferi[24];
    store64(&xferi,      0);       # result (kernel writes here)
    store64(&xferi + 8,  buf);     # buf
    store64(&xferi + 16, frames);  # frames-in
    var r = syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_READI_FRAMES, &xferi);
    if (r < 0) { return r; }
    return load64(&xferi);  # result field — frames-actually-read
}

# ================================================================
# Convenience: write raw byte buffer
# ================================================================

# Write raw PCM bytes. Calculates frame count from byte count.
# bytes_per_frame = channels * (bit_depth / 8).
fn audio_write_bytes(dev, buf, num_bytes): i64 {
    var bpf = audio_channels(dev) * (audio_bit_depth(dev) / 8);
    if (bpf == 0) { return 0 - 1; }
    var frames = num_bytes / bpf;
    return audio_write(dev, buf, frames);
}

# ================================================================
# Status query
# ================================================================

# Query current PCM device state. snd_pcm_status is 192 bytes; the
# `state` field is at offset 0.
fn audio_get_state(dev): i64 {
    var status[192];
    memset(&status, 0, 192);
    var r = syscall(SYS_IOCTL, load64(dev), SNDRV_PCM_IOCTL_STATUS, &status);
    if (r < 0) { return 0 - 1; }
    return load64(&status);
}

# Check if PCM device is in running state
fn audio_is_running(dev): i64 {
    return audio_get_state(dev) == SND_PCM_STATE_RUNNING;
}
